    "Edit", "Write", "NotebookEdit",
    # AT-29:实现方必须能运行项目测试。可信-agent模型下开放 Bash,仓库副作用仍由
    # allowed_paths/提交契约/收尾审计约束;push/merge/network 不再声称被硬阻止。
    "Bash",
]
