try:  # POSIX 独占锁:进程死亡(含 SIGKILL)时由 OS 释放,是判定 orphan 的硬证据
    import fcntl
except ImportError:  # pragma: no cover —— 非 POSIX 平台退化为 pid 探测
    fcntl = None

# 项目护栏:确认 worktree 确实是预期项目,而不是随手指到的别的仓库。
# 迁出 xds-bridge 后不再硬编码 `collab/`:默认只要求"是 git 工作树"
