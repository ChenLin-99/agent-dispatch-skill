# 之所以保留这个钩子:XDS 时代它挡住过把信封指错仓库的低级错误。
REPO_MARKER = os.environ.get("DISPATCH_REPO_MARKER", "")
BASE_CLAUDE_TOOLS = ["Read", "Grep", "Glob", "LS"]
